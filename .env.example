# Managed upstream mode (default): MCP auto-starts bundled hltv-api-fixed/app.py.
HLTV_UPSTREAM_MANAGED=true
HLTV_UPSTREAM_HOST=127.0.0.1
HLTV_UPSTREAM_PORT=18020
# Keep blank to use safe repo-root defaults from src/config/env.ts.
HLTV_UPSTREAM_WORKDIR=
HLTV_UPSTREAM_PYTHON_PATH=
HLTV_UPSTREAM_HEALTH_PATH=/healthz
HLTV_UPSTREAM_START_TIMEOUT_MS=15000

# External upstream mode: set HLTV_UPSTREAM_MANAGED=false and configure API URLs below.
HLTV_API_BASE_URL=http://127.0.0.1:8020
# Optional: if MCP runs inside WSL but hltv-scraper-api runs on the Windows host,
# set this to a Windows-reachable address like http://172.x.x.1:8020 when auto-detect is not enough.
HLTV_API_FALLBACK_BASE_URL=
HLTV_API_TIMEOUT_MS=8000
DEFAULT_RESULT_LIMIT=5
SUMMARY_MODE=template
MCP_SERVER_NAME=hltv-mcp-service
MCP_SERVER_VERSION=0.3.0
